generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String

  sessions Session[]
  role     Role      @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Session {
  id     String @id @default(cuid())
  userId String

  deviceType DeviceType?
  deviceName String?
  userAgent  String?
  ipAddress  String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String @id @default(cuid())
  sessionId String @unique

  tokenHash String @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([expiresAt])
}

enum Role {
  user
  admin
}

enum DeviceType {
  laptop
  phone
  tablet
}
